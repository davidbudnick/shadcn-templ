// --- Breadcrumb ---

templ BreadcrumbDemo() {
	@ui.Breadcrumb("", nil) {
		@ui.BreadcrumbList("", nil) {
			@ui.BreadcrumbItem("", nil) {
				@ui.BreadcrumbLink("/", "", nil) {
					Home
				}
